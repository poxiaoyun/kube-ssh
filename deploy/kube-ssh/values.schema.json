{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "kubeSsh": {
      "type": "object",
      "title": "SSH gateway",
      "properties": {
        "advertiseAddresses": {
          "type": "array",
          "title": "Advertise addresses",
          "description": "Externally reachable host:port addresses published to Access status. Multiple addresses are supported.",
          "examples": [["ssh.example.com:2222"]],
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1,
            "pattern": "^(\\[[0-9A-Fa-f:.]+\\]|[a-z0-9]([-a-z0-9]*[a-z0-9])?(\\.[a-z0-9]([-a-z0-9]*[a-z0-9])?)*):([1-9]|[1-9][0-9]{1,3}|[1-5][0-9]{4}|6[0-4][0-9]{3}|65[0-4][0-9]{2}|655[0-2][0-9]|6553[0-5])$"
          }
        },
        "service": {
          "type": "object",
          "title": "Service",
          "properties": {
            "type": {
              "type": "string",
              "title": "Service type",
              "enum": ["ClusterIP", "NodePort", "LoadBalancer"]
            },
            "nodePorts": {
              "type": "object",
              "properties": {
                "ssh": {
                  "type": "integer",
                  "title": "SSH node port",
                  "minimum": 30000,
                  "maximum": 32767
                }
              }
            }
          }
        }
      }
    }
  }
}

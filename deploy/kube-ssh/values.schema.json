{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "kubeSsh": {
      "type": "object",
      "title": "SSH gateway",
      "properties": {
        "gatewayClassName": {
          "type": "string",
          "title": "Gateway class name",
          "description": "Leave empty to handle only Access objects without a gateway class.",
          "maxLength": 253,
          "pattern": "^$|^[a-z0-9]([-a-z0-9]*[a-z0-9])?(\\.[a-z0-9]([-a-z0-9]*[a-z0-9])?)*$"
        },
        "advertiseAddresses": {
          "type": "array",
          "title": "Advertise addresses",
          "description": "Externally reachable host:port addresses published to Access status. Multiple addresses are supported.",
          "examples": [["ssh.example.com:2222"]],
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1,
            "pattern": "^(\\[[0-9A-Fa-f:.]+\\]|[a-z0-9]([-a-z0-9]*[a-z0-9])?(\\.[a-z0-9]([-a-z0-9]*[a-z0-9])?)*):([1-9]|[1-9][0-9]{1,3}|[1-5][0-9]{4}|6[0-4][0-9]{3}|65[0-4][0-9]{2}|655[0-2][0-9]|6553[0-5])$"
          }
        },
        "hostKey": {
          "type": "object",
          "properties": {
            "autoGenerate": {
              "type": "boolean",
              "description": "Generate a persistent Ed25519 host key when no existing or inline key is configured."
            }
          }
        }
      }
    }
  }
}
